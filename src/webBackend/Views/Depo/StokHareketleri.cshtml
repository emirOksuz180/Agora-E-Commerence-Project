@model List<webBackend.Models.StokHareketViewModel>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Stok Hareketleri Geçmişi";

    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    var filter = (webBackend.Models.StokHareketFilterViewModel)ViewBag.Filter;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 text-dark"><i class="fa-solid fa-clock-rotate-left me-2"></i>Stok Hareket Geçmişi</h4>
    <span class="badge bg-secondary fs-6">Sayfa @currentPage / @totalPages</span>
</div>

<form method="get" id="filterForm" class="row g-3 mb-4 bg-white p-3 rounded shadow-sm border">
    <div class="col-md-3">
        <label class="form-label small fw-bold">Ürün Adı</label>
        <input type="text" name="ProductName" value="@filter?.ProductName" class="form-control" placeholder="Ürün adı ara...">
    </div>
    <div class="col-md-3">
        <label class="form-label small fw-bold">Lokasyon Barkod</label>
        <input type="text" name="LocationBarcode" value="@filter?.LocationBarcode" class="form-control" placeholder="Barkod...">
    </div>
    <div class="col-md-3">
        <label class="form-label small fw-bold">Hareket Tipi</label>
        <select name="MovementType" class="form-select">
            <option value="">Tümü</option>
            <option value="Mal Kabul" selected="@(filter?.MovementType == "Mal Kabul")">Mal Kabul</option>
            <option value="Sipariş" selected="@(filter?.MovementType == "Sipariş")">Sipariş</option>
            <option value="İptal" selected="@(filter?.MovementType == "İptal")">İptal</option>
            <option value="İade" selected="@(filter?.MovementType == "İade")">İade</option>
        </select>
    </div>
    <div class="col-md-3">
        <label class="form-label small fw-bold">İşlemi Yapan</label>
        <input type="text" name="PerformedBy" value="@filter?.PerformedBy" class="form-control" placeholder="Kullanıcı adı...">
    </div>
    <div class="col-md-3">
        <label class="form-label small fw-bold">Başlangıç</label>
        <input type="date" id="startDate" name="StartDate" class="form-control" value="@(filter?.StartDate?.ToString("yyyy-MM-dd"))">
    </div>
    <div class="col-md-3">
        <label class="form-label small fw-bold">Bitiş</label>
        <input type="date" id="endDate" name="EndDate" class="form-control" value="@(filter?.EndDate?.ToString("yyyy-MM-dd"))">
    </div>
    <div class="col-md-6 d-flex align-items-end gap-2">
        <a href="@Url.Action("StokHareketleri")" class="btn btn-outline-secondary w-50">
            <i class="fa-solid fa-rotate-left me-2"></i>Temizle
        </a>
        <button type="submit" class="btn btn-dark w-50">
            <i class="fa-solid fa-filter me-2"></i>Filtrele
        </button>
    </div>
</form>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-striped align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Tarih / Saat</th>
                        <th>İşlem Tipi</th>
                        <th>Ürün Bilgisi</th>
                        <th>Raf</th>
                        <th class="text-center">Miktar</th>
                        <th>İşlemi Yapan</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">Kriterlere uygun hareket bulunamadı.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var log in Model)
                        {
                            <tr>
                                <td class="text-nowrap">@log.MovementDate.ToString("dd.MM.yyyy HH:mm")</td>
                                <td>
                                    <span class="badge @(log.QuantityChange > 0 ? "bg-success" : "bg-danger")">@log.MovementType</span>
                                </td>
                                <td class="fw-bold">@log.ProductName</td>
                                <td><span class="text-primary font-monospace">@log.LocationBarcode</span></td>
                                <td class="text-center">
                                    <span class="badge bg-dark">@(log.QuantityChange > 0 ? "+" + log.QuantityChange : log.QuantityChange)</span>
                                </td>
                                <td>@log.PerformedBy</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (totalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" href="@Url.Action("StokHareketleri", new { 
                        page = i, 
                        startDate = filter?.StartDate?.ToString("yyyy-MM-dd"), 
                        endDate = filter?.EndDate?.ToString("yyyy-MM-dd"),
                        productName = filter?.ProductName,
                        locationBarcode = filter?.LocationBarcode,
                        movementType = filter?.MovementType,
                        performedBy = filter?.PerformedBy
                    })">@i</a>
                </li>
            }
        </ul>
    </nav>
}

@section Scripts {
    <script>
        const startInput = document.getElementById('startDate');
        const endInput = document.getElementById('endDate');
        
        function syncDateLimits() {
            if (startInput.value) endInput.min = startInput.value;
            if (endInput.value) startInput.max = endInput.value;
        }
        syncDateLimits();
        startInput.addEventListener('change', syncDateLimits);
        endInput.addEventListener('change', syncDateLimits);
    </script>
}