@model List<webBackend.Models.StockGroupViewModel>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Stok Yönetim Paneli";
}

<div class="card shadow border-dark mb-4">
    <div class="card-header bg-dark text-white py-3 d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0"><i class="fa-solid fa-boxes-stacked me-2"></i>Stok Yönetimi (Gruplanmış)</h5>
        <a href="/Depo/MalKabul" class="btn btn-success btn-sm"><i class="fa-solid fa-plus me-1"></i> Yeni Mal Kabul</a>
    </div>
    
    <div class="card-body bg-light">
        @Html.AntiForgeryToken()

        <div class="accordion" id="stockAccordion">
            @foreach (var product in Model)
            {
                <div class="accordion-item mb-2 shadow-sm border-0">
                    <h2 class="accordion-header" id="heading-@product.ProductId">
                        <button class="accordion-button collapsed bg-white" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-@product.ProductId">
                            <div class="d-flex w-100 justify-content-between align-items-center me-3">
                                <span><i class="fa-solid fa-box-open me-2 text-primary"></i><strong>@product.ProductName</strong></span>
                                <span class="badge bg-dark fs-6">Toplam: @product.TotalAvailableQuantity</span>
                            </div>
                        </button>
                    </h2>
                    
                    <div id="collapse-@product.ProductId" class="accordion-collapse collapse" data-bs-parent="#stockAccordion">
                        <div class="accordion-body bg-white p-0">
                            <table class="table table-hover table-striped mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Lokasyon Barkodu</th>
                                        <th class="text-center">Miktar</th>
                                        <th class="text-center">İşlemler</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var loc in product.Locations)
                                    {
                                        <tr id="row-@product.ProductId-@loc.LocationBarcode">
                                            <td class="align-middle">
                                                <span class="badge bg-secondary font-monospace">@loc.LocationBarcode</span>
                                            </td>
                                            <td class="text-center fw-bold text-primary align-middle" id="qty-@product.ProductId-@loc.LocationBarcode">
                                                @loc.Quantity
                                            </td>
                                            <td class="text-center">
                                                <button type="button" class="btn btn-warning btn-sm me-1 btn-adjust"
                                                        data-productid="@product.ProductId"
                                                        data-productname="@product.ProductName"
                                                        data-barcode="@loc.LocationBarcode"
                                                        data-qty="@loc.Quantity">
                                                    <i class="fa-solid fa-pen-to-square"></i> Düzelt
                                                </button>
                                                <button type="button" class="btn btn-danger btn-sm btn-delete"
                                                        data-productid="@product.ProductId"
                                                        data-barcode="@loc.LocationBarcode">
                                                    <i class="fa-solid fa-trash-can"></i> Sil
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="adjustModal" tabindex="-1" aria-hidden="true">
    @* Modal içeriğin aynen kalabilir, sadece scriptte ID'lere dikkat *@
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-warning">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title fw-bold">Stok Miktarı Düzeltme</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body bg-light">
                <form id="frmAdjust">
                    <input type="hidden" id="mdlProductId" name="ProductId" />
                    <input type="hidden" id="mdlLocationBarcode" name="LocationBarcode" />
                    <div class="mb-3">
                        <label class="form-label fw-bold">Ürün:</label>
                        <input type="text" id="mdlProductName" class="form-control" readonly />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Raf:</label>
                        <input type="text" id="mdlBarcodeDisplay" class="form-control" readonly />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold text-danger">Yeni Miktar:</label>
                        <input type="number" id="mdlNewQuantity" name="NewQuantity" class="form-control" min="0" required />
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Vazgeç</button>
                <button type="button" id="btnSubmitAdjust" class="btn btn-warning fw-bold">Kaydet</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // AJAX kodların tamamen aynı kalabilir, çünkü butonlardaki data- attributes yapısını 
        // ve ID yapısını (row-productId-barcode) koruduk. 
        // jQuery seçicilerin sorunsuz çalışacaktır.
        $(document).ready(function () {
             // ... Mevcut Script'in aynen kalacak ...
        });
    </script>
}