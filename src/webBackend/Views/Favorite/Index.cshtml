@using webBackend.Controllers
@model List<FavoriteViewModel>

@section Bar {
    <section class="bg-primary p-3">
        <div class="container">
            <nav>
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item">
                        <a asp-controller="Home" asp-action="Index" class="text-white text-decoration-none">Anasayfa</a>
                    </li>
                    <li class="breadcrumb-item text-white-50">Favorilerim</li>
                </ol>
            </nav>
        </div>
    </section>
}

<section class="mt-3">
    <div class="container">
        <div class="row">
            @* 1. SOL KOLON: ACCOUNT SIDEBAR *@
            <div class="col-md-3">
                <div class="list-group mb-3 shadow-sm">
                    @await Html.PartialAsync("Partials/Site/_AccountSideBar")
                </div>
            </div>

            @* 2. SAĞ KOLON: ANA İÇERİK *@
            <div class="col-md-9">
                <div class="row">
                    @if (Model == null || !Model.Any())
                    {
                        <div class="col-12">
                            <div class="alert alert-light text-center p-5 shadow-sm border-0">
                                <i class="fa-regular fa-heart fa-3x mb-3 text-muted"></i>
                                <h5>Henüz favori ürününüz yok.</h5>
                                <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-3 px-4">Alışverişe Başla</a>
                            </div>
                        </div>
                    }
                    else
                    {
                        @* FAVORİ ÜRÜN LİSTESİ *@
                        <div class="col-lg-8">
                            <div class="card border-0 shadow-sm rounded-3 mb-3">
                                <div class="card-header bg-white py-3 border-bottom-0">
                                    <h6 class="mb-0 fw-bold">
                                        <i class="fa-solid fa-heart text-danger me-2"></i>Favori Ürünlerim
                                    </h6>
                                </div>
                                <ul class="list-group list-group-flush">
                                    @foreach (var item in Model)
                                    {
                                        <li class="p-3 list-group-item border-0 border-bottom">
                                            <div class="row align-items-center">
                                                <div class="col-3 col-md-2">
                                                    <img src="@item.ImageUrl" class="img-fluid rounded border" 
                                                         style="aspect-ratio: 1/1; object-fit: cover;" 
                                                         onerror="this.src='/images/no-image.png'">
                                                </div>
                                                <div class="col-6 col-md-6">
                                                    <h6 class="mb-1 text-dark fw-bold small">@item.ProductName</h6>
                                                    <span class="text-primary fw-bold">@item.Price.ToString("N2") ₺</span>
                                                    @if (item.AddedDate != default(DateTime))
                                                    {
                                                        <div class="text-muted" style="font-size: 0.75rem;">
                                                            Ekleme: @item.AddedDate.ToString("dd.MM.yyyy")
                                                        </div>
                                                    }
                                                </div>
                                                <div class="col-3 col-md-4 text-end">
                                                    <div class="d-flex flex-column gap-2">
                                                        
                                                        @* ÇALIŞAN SEPETE EKLEME FORMU (MODİFİYE EDİLDİ) *@
                                                        <form action="/Cart/AddToCart" method="post">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="urunId" value="@item.ProductId">
                                                            <button type="submit" class="btn btn-sm btn-outline-warning w-100 shadow-sm fw-bold text-dark">
                                                                <i class="fa fa-shopping-basket me-1"></i> Sepete Ekle
                                                            </button>
                                                        </form>

                                                        @* SİLME BUTONU *@
                                                        <a asp-controller="Favorite" 
                                                           asp-action="DeleteFavorite" 
                                                           asp-route-id="@item.FavoriteId" 
                                                           class="btn btn-sm btn-light text-danger border-0 small"
                                                           onclick="return confirm('Favorilerden kaldırılsın mı?')">
                                                            <i class="fa-solid fa-trash me-1"></i> Kaldır
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </li>
                                    }
                                </ul>
                            </div>
                        </div>

                        @* FAVORİ ÖZETİ KARTI *@
                        <div class="col-lg-4">
                            <div class="card border-0 shadow-sm rounded-3 position-sticky" style="top: 20px;">
                                <div class="card-body p-4 text-center">
                                    <div class="mb-3">
                                        <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 55px; height: 55px;">
                                            <i class="fa-solid fa-star fa-lg"></i>
                                        </div>
                                    </div>
                                    <h6 class="fw-bold mb-2">Favori Özeti</h6>
                                    <p class="text-muted small">
                                        Listenizde toplam <span class="badge bg-light text-dark border">@Model.Count</span> ürün bulunuyor.
                                    </p>
                                    <hr class="my-3 opacity-25">
                                    <div class="d-grid gap-2">
                                        <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-sm py-2 shadow-sm">
                                            <i class="fa-solid fa-magnifying-glass me-2 small"></i>Keşfetmeye Devam
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>