@model List<KategoriGetModel>

@{
  Layout = "_AdminLayout";
}


<div class="row">
      <div class="col">
        <div class="card shadow">
          <div class="card-header py-1 d-flex justify-content-between align-items-center">
            <h5 class="card-title">Kategoriler</h5>
            @if (User.IsInRole("Admin") || User.HasClaim("Permission", "Category.Create"))
            {
              <a asp-controller="Kategori" asp-action="Create" class="btn btn-sm btn-primary">
              <i class="fa-solid fa-plus"></i>
              </a>
            }
          </div>
          <div class="card-body">
            
            

            <div class="table-responsive">
              <table class="table table-bordered table spriped mb-0">
              <thead class="table-secondary">
                <tr>
                  <th>ID</th>
                  <th>Kategori Adı</th>
                  <th>URL</th>
                  <th>Ürün Sayısı</th>
                  <th style="width: 150px;"></th>
                </tr>
              </thead>
              <tbody>

              @foreach(var cat in Model) {
                <tr>                  
                  <td>@cat.Id</td>
                  <td>@cat.Name</td>
                  <td>@cat.Url</td>
                  <td>@cat.ProductCount</td>
                  <td style="wdith: 150px;">
                    @if (User.IsInRole("Admin") || User.HasClaim("Permission", "Category.Edit")) {
                      <a asp-controller="Kategori" asp-action="Edit" asp-route-id="@cat.Id" class="btn btn-primary btn-sm me-2">
                      <i class="fa-solid fa-pen-to-square"></i>
                      </a>
                    }
                    
                    @if (User.IsInRole("Admin") || User.HasClaim("Permission", "Product.View")) {

                      <a asp-controller="Urun" asp-route-kategori = "@cat.Id" class="btn btn-primary btn-sm">
                      <i class="fa-solid fa-right-long"></i>
                      </a>

                    }
                    

                    @if (User.IsInRole("Admin") || User.HasClaim("Permission", "Category.Delete")) {

                      @if(cat.ProductCount == 0) {
                      <a asp-controller="Kategori" asp-action="Delete" asp-route-id="@cat.Id" class="btn btn-danger btn-sm me-2">
                        <i class="fa-solid fa-trash"></i>
                      </a>
                      }

                    }
                    

                    
                  </td>
                </tr>
              }
                
              </tbody>
            </table>
            </div>
          </div>
        </div>
      </div>
</div>