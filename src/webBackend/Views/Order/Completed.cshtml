@model int 

@section Bar {
    <section class="bg-primary p-3">
        <div class="container">
            <nav>
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item">
                        <a asp-controller="Home" asp-action="Index" class="text-white">Anasayfa</a>
                    </li>
                    <li class="breadcrumb-item text-white-50">
                        Siparişiniz Tamamlandı
                    </li>
                </ol>
            </nav>
        </div>
    </section>
}

<div class="card card-body my-5 text-center shadow-sm">
  <div class="mb-3">
      <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
  </div>
  
  <h1 class="h3 fw-bold">Teşekkür Ederiz, Emir!</h1>
  <p class="lead">
    <strong>#@Model</strong> numaralı siparişiniz başarıyla kaydedildi.
  </p>
  <p class="text-muted">
      Sipariş detaylarınız e-posta adresinize gönderilecektir.
  </p>
  
  <div class="mt-4">
    <a asp-controller="Order" asp-action="OrderList" class="btn btn-primary btn-lg px-5">
        Siparişlerimi Görüntüle
    </a>
    
    <div class="mt-3">
        <a asp-controller="Home" asp-action="Index" class="btn btn-link text-decoration-none">
            Alışverişe Devam Et
        </a>
    </div>
  </div>
</div>