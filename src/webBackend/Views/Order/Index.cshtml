@model List<Order>
@{
    Layout = "_AdminLayout";
}

<div class="row">
    <div class="col">

        @await Html.PartialAsync("Partials/Admin/_AdminCards")

        <div class="card shadow mb-4">

            <div class="card-header py-3">
                <h5 class="m-0 font-weight-bold text-primary">
                    Sipariş Yönetimi & Filtreleme
                </h5>
            </div>

            <div class="card-body">

                <!-- QUICK DATE FILTER -->
                <div class="mb-3">
                    <div class="btn-group w-100">

                        <a href="?range=7"
                           class="btn btn-sm @(ViewBag.Range == "7" ? "btn-primary" : "btn-outline-secondary")">
                            Son 7 Gün
                        </a>

                        <a href="?range=30"
                           class="btn btn-sm @(ViewBag.Range == "30" ? "btn-primary" : "btn-outline-secondary")">
                            Son 30 Gün
                        </a>

                        <a href="?range=thisMonth"
                           class="btn btn-sm @(ViewBag.Range == "thisMonth" ? "btn-primary" : "btn-outline-secondary")">
                            Bu Ay
                        </a>

                        <a href="?range=lastMonth"
                           class="btn btn-sm @(ViewBag.Range == "lastMonth" ? "btn-primary" : "btn-outline-secondary")">
                            Geçen Ay
                        </a>

                        <a href="?range=thisYear"
                           class="btn btn-sm @(ViewBag.Range == "thisYear" ? "btn-primary" : "btn-outline-secondary")">
                            Bu Yıl
                        </a>

                    </div>
                </div>

                <!-- FİLTRE FORMU -->
                <form id="adminFilterForm"
                      method="get"
                      asp-action="Index"
                      class="row g-3 mb-4">

                    <div class="col-md-3">
                        <input type="text"
                               name="email"
                               class="form-control"
                               placeholder="Müşteri E-mail..."
                               value="@Context.Request.Query["email"]">
                    </div>

                    <div class="col-md-3">
                        <select name="statusId" class="form-select">
                            <option value="">Tüm Durumlar</option>

                            @foreach (var status in (List<OrderStatus>)ViewBag.Statuses)
                            {
                                <option value="@status.Id"
                                        selected="@(Context.Request.Query["statusId"] == status.Id.ToString())">
                                    @status.StatusDisplayName
                                </option>
                            }
                        </select>
                    </div>

                    <div class="col-md-4">
                        <div class="input-group">
                            <input id="startDate"
                                   type="date"
                                   name="startDate"
                                   class="form-control"
                                   value="@(ViewBag.Range != null ? "" : Context.Request.Query["startDate"])">

                            <span class="input-group-text">-</span>

                            <input id="endDate"
                                   type="date"
                                   name="endDate"
                                   class="form-control"
                                   value="@(ViewBag.Range != null ? "" : Context.Request.Query["endDate"])">
                        </div>
                    </div>

                    <div class="col-md-2">
                        <button type="submit"
                                class="btn btn-primary w-100">
                            Filtrele
                        </button>
                    </div>

                    <a href="@Url.Action("Index")"
                        class="btn btn-outline-secondary btn-sm"
                        title="Temizle">
                        <i class="fa-solid fa-rotate-left"></i>
                    </a>

                </form>

                <div id="dateValidationMessage"
                     class="text-danger small fw-semibold mb-3"
                     style="display:none;">
                </div>

                <!-- ORDER TABLE -->
                <div class="table-responsive">
                    <table class="table table-bordered table-hover mb-0">

                        <thead class="table-dark text-nowrap">
                            <tr>
                                <th>Sipariş No</th>
                                <th>Müşteri Ad Soyad</th>
                                <th>E-mail</th>
                                <th>Toplam Tutar</th>
                                <th>Statü Güncelle</th>
                                <th>Sipariş Tarihi</th>
                                <th style="width:50px;">Detay</th>
                            </tr>
                        </thead>

                        <tbody>

                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    <tr>

                                        <td class="align-middle fw-bold">
                                            #@item.Id
                                        </td>

                                        <td class="align-middle">
                                            @item.Ad @item.Soyad
                                        </td>

                                        <td class="align-middle">
                                            @item.Email
                                        </td>

                                        <td class="align-middle text-primary fw-bold">
                                            @item.ToplamFiyat.ToString("N2") ₺
                                        </td>

                                        <td class="align-middle" style="min-width:180px;">

                                            <form asp-controller="Order"
                                                  asp-action="UpdateStatus"
                                                  method="post">

                                                <input type="hidden"
                                                       name="orderId"
                                                       value="@item.Id" />

                                                <select name="newStatusId"
                                                        class="form-select form-select-sm shadow-sm"
                                                        onchange="this.form.submit()">

                                                    @foreach (var status in (List<OrderStatus>)ViewBag.Statuses)
                                                    {
                                                        <option value="@status.Id"
                                                                selected="@(item.StatusId == status.Id)">
                                                            @status.StatusDisplayName
                                                        </option>
                                                    }

                                                </select>

                                            </form>

                                        </td>

                                        <td class="align-middle">
                                            @item.SiparisTarihi.ToString("dd.MM.yyyy HH:mm")
                                        </td>

                                        <td class="text-center">
                                            <a asp-controller="Order"
                                               asp-action="Details"
                                               asp-route-id="@item.Id"
                                               class="btn btn-outline-primary btn-sm">
                                                <i class="fa-solid fa-magnifying-glass"></i>
                                            </a>
                                        </td>

                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7"
                                        class="text-center py-4 text-muted">
                                        Aranan kriterlere uygun sipariş bulunamadı.
                                    </td>
                                </tr>
                            }

                        </tbody>
                    </table>
                </div>

                <!-- PAGINATION -->
                <nav class="mt-4">
                    <ul class="pagination justify-content-center">

                        @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
                        {
                            <li class="page-item @(i == (int)ViewBag.CurrentPage ? "active" : "")">

                                <a class="page-link"
                                   href="@Url.Action("Index",
                                   new {
                                       page = i,
                                       email = Context.Request.Query["email"],
                                       statusId = Context.Request.Query["statusId"],
                                       startDate = Context.Request.Query["startDate"],
                                       endDate = Context.Request.Query["endDate"],
                                       range = ViewBag.Range
                                   })">
                                    @i
                                </a>

                            </li>
                        }

                    </ul>
                </nav>

            </div>
        </div>
    </div>
</div>

@section Scripts {

<script>

$('#adminFilterForm').on('submit', function (e) {

    var start = $('#startDate').val();
    var end = $('#endDate').val();
    var messageBox = $('#dateValidationMessage');

    messageBox.hide().text('');

    if (!start && !end)
        return true;

    if (start && end) {

        var startDate = new Date(start);
        var endDate = new Date(end);

        if (startDate > endDate) {
            e.preventDefault();
            messageBox.text('Başlangıç tarihi bitiş tarihinden sonra olamaz.')
                      .fadeIn();
            return false;
        }
    }

    if (!start && end) {
        e.preventDefault();
        messageBox.text('Bitiş tarihi girildiğinde başlangıç tarihi de seçilmelidir.')
                  .fadeIn();
        return false;
    }

    return true;
});

</script>

}