@model List<Order>

@{
    Layout = "_AdminLayout";
}

<div class="row">
    <div class="col">
        @await Html.PartialAsync("Partials/Admin/_AdminCards")
        <div class="card shadow ">
            <div class="card-header py-2">
                <h5 class="card-title mb-0">Siparişler</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-striped mb-0">
                        <thead class="table-secondary text-nowrap">
                            <tr>
                                <th>Sipariş No</th>
                                <th>Müşteri Ad Soyad</th>
                                <th>Toplam Tutar</th>
                                <th>Sipariş Tarihi</th>
                                <th style="width: 50px;">İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="align-middle">#@item.Id</td>
                                        <td class="align-middle">@item.AdSoyad</td>
                                        <td class="align-middle text-primary fw-bold">@item.ToplamFiyat.ToString("N2") ₺</td>
                                        <td class="align-middle">@item.SiparisTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                                        @* <td class="align-middle">
                                            
                                            @switch (item.SiparisDurumu) /
                                            {
                                                case "Beklemede":
                                                    <span class="badge bg-warning text-dark">Onay Bekliyor</span>
                                                    break;
                                                case "Kargoda":
                                                    <span class="badge bg-info text-white">Kargoya Verildi</span>
                                                    break;
                                                case "Teslim Edildi":
                                                    <span class="badge bg-success text-white">Teslim Edildi</span>
                                                    break;
                                                default:
                                                    <span class="badge bg-secondary text-white">@item.SiparisDurumu</span>
                                                    break;
                                            }
                                        </td> *@
                                        <td class="text-center">
                                            <a asp-controller="Order" asp-action="Details" asp-route-id="@item.Id"
                                               class="btn btn-primary btn-sm" title="Detayları Gör">
                                                <i class="fa-solid fa-right-long"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-4">
                                        <i class="fa-solid fa-inbox fa-2x mb-2 d-block text-muted"></i>
                                        Henüz kaydedilmiş bir sipariş bulunamadı.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>