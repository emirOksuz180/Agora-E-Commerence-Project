@model OrderCreateModel

@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "~/Views/Shared/_SiteLayout.cshtml";

    if (Model == null)
    {
        <div class="container mt-5">
            <div class="alert alert-warning shadow-sm">
                <i class="fa fa-exclamation-triangle me-2"></i>
                Sipariş bilgileri yüklenemedi. Lütfen sepetinize dönüp tekrar deneyin.
                <a href="/Cart" class="alert-link">Sepete Dön</a>
            </div>
        </div>

        return;
    }
}

@section Bar {
    <section class="bg-primary py-3 shadow-sm">
        <div class="container">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item">
                        <a href="/" class="text-white text-decoration-none">
                            Anasayfa
                        </a>
                    </li>

                    <li class="breadcrumb-item">
                        <a href="/Account/Orders" class="text-white text-decoration-none">
                            Siparişlerim
                        </a>
                    </li>

                    <li class="breadcrumb-item active text-white" aria-current="page">
                        Checkout
                    </li>
                </ol>
            </nav>
        </div>
    </section>
}

<section class="mt-4 mb-5">
    <div class="container">

        <form method="post" id="checkoutForm">

            <div asp-validation-summary="ModelOnly"
                 class="alert alert-danger shadow-sm">
            </div>

            <div class="row g-4">

                <!-- SOL PANEL -->
                <div class="col-lg-8">

                    @* Varsayılan Adres *@
                    @if (Model.DefaultAddress != null)
                    {
                        <div class="card border-primary shadow-sm mb-4"
                             id="defaultAddressCard">

                            <div class="card-body">

                                <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">

                                    <div>
                                        <h5 class="text-primary fw-bold mb-2">
                                            <i class="fa-solid fa-location-dot me-2"></i>
                                            @Model.DefaultAddress.AddressTitle
                                        </h5>

                                        <div class="small text-muted">

                                            <div class="mb-1">
                                                <strong>Alıcı:</strong>
                                                @Model.DefaultAddress.FirstName
                                                @Model.DefaultAddress.LastName
                                            </div>

                                            <div class="mb-1">
                                                <strong>Adres:</strong>
                                                @Model.DefaultAddress.AddressDetail
                                            </div>

                                            <div>
                                                <strong>Konum:</strong>
                                                @Model.DefaultAddress.District /
                                                @Model.DefaultAddress.City
                                            </div>

                                        </div>
                                    </div>

                                    <div class="form-check form-switch mt-1">
                                        <input class="form-check-input"
                                               type="checkbox"
                                               asp-for="UseDefaultAddress"
                                               id="chkUseDefault">

                                        <label class="form-check-label fw-semibold small"
                                               for="chkUseDefault">
                                            Bu adresi kullan
                                        </label>
                                    </div>

                                </div>

                            </div>
                        </div>
                    }

                    @* Teslimat Adresi *@
                    <div class="card border-0 shadow-sm mb-4"
                         id="deliveryAddressSection"
                         style="@(Model.DefaultAddress != null ? "display:none;" : "")">

                        <div class="card-header bg-white border-bottom py-3">
                            <h2 class="h5 fw-bold mb-0">
                                Teslimat Adresi Bilgileri
                            </h2>
                        </div>

                        <div class="card-body">

                            <div class="row g-3 mb-3">

                                <div class="col-md-6">
                                    <label asp-for="Ad" class="form-label fw-semibold">
                                        Ad
                                    </label>

                                    <input asp-for="Ad"
                                           class="form-control"
                                           placeholder="Adınız">

                                    <span asp-validation-for="Ad"
                                          class="text-danger small"></span>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="Soyad" class="form-label fw-semibold">
                                        Soyad
                                    </label>

                                    <input asp-for="Soyad"
                                           class="form-control"
                                           placeholder="Soyadınız">

                                    <span asp-validation-for="Soyad"
                                          class="text-danger small"></span>
                                </div>

                            </div>

                            <div class="mb-3">

                                <label asp-for="Email"
                                       class="form-label fw-semibold">
                                    E-Posta Adresi
                                </label>

                                <input asp-for="Email"
                                       type="email"
                                       class="form-control"
                                       placeholder="ornek@mail.com">

                                <span asp-validation-for="Email"
                                      class="text-danger small"></span>

                            </div>

                            <div class="row g-3 mb-3">

                                <div class="col-md-4">

                                    <label asp-for="Sehir"
                                           class="form-label fw-semibold">
                                        Şehir
                                    </label>

                                    <select asp-for="Sehir"
                                            id="ddlSehir"
                                            asp-items="@(ViewBag.Iller as SelectList)"
                                            class="form-select">

                                        <option value="">
                                            Şehir Seçiniz...
                                        </option>

                                    </select>

                                    <span asp-validation-for="Sehir"
                                          class="text-danger small"></span>

                                </div>

                                 <div class="col-md-4">

                                    <label asp-for="Ilce"
                                           class="form-label fw-semibold">
                                        İlçe
                                    </label>

                                    <select asp-for="Ilce"
                                            id="ddlIlce"
                                            asp-items="@(ViewBag.Ilceler as SelectList)"
                                            class="form-select">

                                        <option value="">
                                            Önce Şehir Seçiniz
                                        </option>

                                    </select>

                                    <span asp-validation-for="Ilce"
                                          class="text-danger small"></span>

                                </div> 

                                <div class="col-md-4">

                                    <label asp-for="Telefon"
                                           class="form-label fw-semibold">
                                        Telefon
                                    </label>

                                    <input asp-for="Telefon"
                                           class="form-control"
                                           placeholder="5xx xxx xxxx">

                                    <span asp-validation-for="Telefon"
                                          class="text-danger small"></span>

                                </div>

                            </div>

                            <div class="row g-3">

                                <div class="col-md-4">

                                    <label asp-for="PostaKodu"
                                           class="form-label fw-semibold">
                                        Posta Kodu
                                    </label>

                                    <input asp-for="PostaKodu"
                                           class="form-control"
                                           placeholder="34000">

                                    <span asp-validation-for="PostaKodu"
                                          class="text-danger small"></span>

                                </div>

                                <div class="col-md-8">

                                    <label asp-for="AdresSatiri"
                                           class="form-label fw-semibold">
                                        Adres Detayı
                                    </label>

                                    <textarea asp-for="AdresSatiri"
                                              id="AdresSatiri"
                                              rows="3"
                                              class="form-control"
                                              placeholder="Mahalle, Sokak, Kapı No"></textarea>

                                    <span asp-validation-for="AdresSatiri"
                                          class="text-danger small"></span>

                                </div>

                            </div>

                        </div>
                    </div>

                    @* Ödeme Bilgileri *@
                    <div class="card border-0 shadow-sm">

                        <div class="card-header bg-white border-bottom py-3">
                            <h2 class="h5 fw-bold mb-0">
                                Ödeme Bilgileri
                            </h2>
                        </div>

                        <div class="card-body">

                            @if (ViewBag.Cart?.Toplam <= 0)
                            {
                                <div class="alert alert-success shadow-sm border-0">
                                    <i class="fa fa-gift me-2"></i>
                                    Bu sipariş ücretsizdir.
                                </div>

                                <input type="hidden"
                                       asp-for="CartNumber"
                                       value="0000000000000000" />
                            }
                            else
                            {
                                <div class="mb-3">

                                    <label asp-for="CartName"
                                           class="form-label fw-semibold">
                                        Kart Üzerindeki İsim
                                    </label>

                                    <input asp-for="CartName"
                                           class="form-control"
                                           placeholder="Ad Soyad">

                                    <span asp-validation-for="CartName"
                                          class="text-danger small"></span>

                                </div>

                                <div class="mb-3">

                                    <label asp-for="CartNumber"
                                           class="form-label fw-semibold">
                                        Kart Numarası
                                    </label>

                                    <div class="input-group">

                                        <span class="input-group-text bg-white">
                                            <i class="fa-solid fa-credit-card text-muted"
                                               id="card-icon"></i>
                                        </span>

                                        <input asp-for="CartNumber"
                                               id="CartNumber"
                                               class="form-control"
                                               maxlength="19"
                                               placeholder="0000 0000 0000 0000">

                                    </div>

                                    <span asp-validation-for="CartNumber"
                                          id="luhn-error"
                                          class="text-danger small"></span>

                                </div>

                                <div class="row g-3">

                                    <div class="col-4">

                                        <label asp-for="CartExpirationMonth"
                                               class="form-label fw-semibold">
                                            Ay
                                        </label>

                                        <input asp-for="CartExpirationMonth"
                                               class="form-control text-center"
                                               maxlength="2"
                                               placeholder="MM">

                                        <span asp-validation-for="CartExpirationMonth"
                                              class="text-danger small"></span>

                                    </div>

                                    <div class="col-4">

                                        <label asp-for="CartExpirationYear"
                                               class="form-label fw-semibold">
                                            Yıl
                                        </label>

                                        <input asp-for="CartExpirationYear"
                                               class="form-control text-center"
                                               maxlength="4"
                                               placeholder="YYYY">

                                        <span asp-validation-for="CartExpirationYear"
                                              class="text-danger small"></span>

                                    </div>

                                    <div class="col-4">

                                        <label asp-for="CartCVV"
                                               class="form-label fw-semibold">
                                            CVV
                                        </label>

                                        <input asp-for="CartCVV"
                                               class="form-control text-center"
                                               maxlength="3"
                                               placeholder="***">

                                        <span asp-validation-for="CartCVV"
                                              class="text-danger small"></span>

                                    </div>

                                </div>
                            }

                        </div>
                    </div>

                </div>

                <!-- SAĞ PANEL -->
                <div class="col-lg-4">

                    <div class="card border-0 shadow-sm sticky-top"
                         style="top: 20px;">

                        <div class="card-header bg-dark text-white py-3">
                            <h2 class="h6 mb-0 text-uppercase">
                                Sipariş Özeti
                            </h2>
                        </div>

                        <div class="card-body">

                            <div class="mb-3">

                                <label class="form-label fw-semibold small">
                                    Kargo Firması
                                </label>

                                <select id="SelectedCarrierId"
                                        asp-for="SelectedCarrierId"
                                        class="form-select"
                                        required>

                                    <option value="">
                                        Seçiniz...
                                    </option>

                                    @if (ViewBag.Carriers != null)
                                    {
                                        foreach (var carrier in (SelectList)ViewBag.Carriers)
                                        {
                                            <option value="@carrier.Value">
                                                @carrier.Text
                                            </option>
                                        }
                                    }

                                </select>

                            </div>

                            <hr>

                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-secondary">Ara Toplam</span>

                                <strong id="subtotal">
                                    @ViewBag.Cart?.Toplam.ToString("C2")
                                </strong>
                            </div>

                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-secondary">Kargo</span>

                                <strong id="shipping-amount">
                                    0,00 TL
                                </strong>
                            </div>

                            <div class="d-flex justify-content-between border-top pt-3 mb-4">

                                <span class="fw-bold">
                                    Genel Toplam
                                </span>

                                <span id="grand-total"
                                      class="fw-bold fs-4 text-success">

                                    @ViewBag.Cart?.Toplam.ToString("C2")

                                </span>

                            </div>

                            <div class="d-grid">

                                <button type="submit"
                                        class="btn btn-warning btn-lg fw-bold shadow-sm">

                                    Ödemeyi Tamamla

                                </button>

                            </div>

                        </div>
                    </div>

                </div>

            </div>

        </form>

    </div>
</section>

@section Scripts {

    <script>
                $(document).ready(function () {
const $chkUseDefault = $('#chkUseDefault');
const $deliverySection = $('#deliveryAddressSection');
const $deliveryInputs = $deliverySection.find('input, select, textarea');
const $cardInput = $('#CartNumber');
const $cardIcon = $('#card-icon');
const $luhnError = $('#luhn-error');
const $shippingAmount = $('#shipping-amount');
const $grandTotal = $('#grand-total');
const $subtotal = $('#subtotal');

        toggleAddressFields($chkUseDefault.is(':checked'), false);

        $chkUseDefault.on('change', function () {
            toggleAddressFields(this.checked, true);
        });

        function toggleAddressFields(isChecked, shouldCalculate) {
            if (isChecked) {
                $deliverySection.slideUp(250);
                $deliveryInputs.prop('disabled', true).removeAttr('required');
                $deliverySection.find('.text-danger').text('');
                $deliverySection.find('.is-invalid').removeClass('is-invalid');
            } else {
                $deliverySection.slideDown(250);
                $deliveryInputs.prop('disabled', false);
            }
            
            if (shouldCalculate) calculateShipping();
        }

        $('#ddlSehir').on('change', function () {
            const cityName = $(this).val();
            const $ddlIlce = $('#ddlIlce');
            $ddlIlce.empty().append('<option value="">İlçe Seçiniz</option>');
            
            if (cityName) {
                $.get('/Order/GetDistricts', { cityName: cityName })
                    .done(function (data) {
                        $.each(data, function (index, item) {
                            $ddlIlce.append($('<option>', { value: item.text, text: item.text }));
                        });
                    });
            }
            calculateShipping();
        });

        $cardInput.on('input', function (e) {
            let value = e.target.value.replace(/\D/g, '');
            let formatted = value.replace(/(\d{4})(?=\d)/g, '$1 ');
            $(this).val(formatted);

            if (value.startsWith('4')) {
                $cardIcon.attr('class', 'fa-brands fa-cc-visa text-primary');
            } else if (/^(5[1-5]|2[2-7])/.test(value)) {
                $cardIcon.attr('class', 'fa-brands fa-cc-mastercard text-danger');
            } else {
                $cardIcon.attr('class', 'fa-solid fa-credit-card text-muted');
            }

            if (value.length >= 13) {
                if (checkLuhn(value)) {
                    $luhnError.hide();
                    $(this).removeClass('is-invalid').addClass('is-valid');
                } else {
                    $luhnError.text('Geçersiz kart numarası!').show();
                    $(this).addClass('is-invalid').removeClass('is-valid');
                }
            }
        });

        function checkLuhn(n) {
            let sum = 0;
            for (let i = 0; i < n.length; i++) {
                let digit = parseInt(n[n.length - 1 - i]);
                if (i % 2 === 1) {
                    digit *= 2;
                    if (digit > 9) digit -= 9;
                }
                sum += digit;
            }
            return sum % 10 === 0;
        }

        $(document).on('change', '#SelectedCarrierId, #ddlSehir, #ddlIlce', calculateShipping);

        function calculateShipping() {
            const carrierId = $('#SelectedCarrierId').val();
            
            const isDefault = $chkUseDefault.is(':checked');
            const city = isDefault ? '@Model.DefaultAddress?.City' : $('#ddlSehir option:selected').text().trim();
            const district = isDefault ? '@Model.DefaultAddress?.District' : $('#ddlIlce option:selected').text().trim();

            if (carrierId && city) {
                $.get('/Order/GetShippingPrice', {
                    carrierId: carrierId,
                    cityName: city,
                    districtName: district
                })
                .done(function (res) {
                    if (res.success) {
                        if (res.isFreeShipping) {
                            $shippingAmount.text('Ücretsiz').removeClass('text-secondary').addClass('text-success fw-bold');
                        } else {
                            $shippingAmount.text(res.shippingPrice.toLocaleString('tr-TR', { minimumFractionDigits: 2 }) + ' TL')
                                .removeClass('text-success fw-bold').addClass('text-secondary');
                        }
                        $grandTotal.text(res.totalPrice.toLocaleString('tr-TR', { minimumFractionDigits: 2 }) + ' TL');
                    } else {
                        resetPrices();
                    }
                })
                .fail(resetPrices);
            } else {
                resetPrices();
            }
        }

        function resetPrices() {
            $shippingAmount.text('0,00 TL').removeClass('text-success fw-bold').addClass('text-secondary');
            $grandTotal.text($subtotal.text());
        }

        if ($('#SelectedCarrierId').val()) {
            calculateShipping();
        }

        $('#checkoutForm').on('submit', function (e) {
            const validator = $(this).validate();
            validator.settings.ignore = $chkUseDefault.is(':checked') ? "#deliveryAddressSection *" : ":hidden";

            if (!$(this).valid()) {
                e.preventDefault();
            }
        });
    });
    </script>



}