@using Duende.IdentityServer.ResponseHandling
@model Order

@{
    bool isAdmin = User.IsInRole("Admin");
    Layout = "~/Views/Shared/_DetailsLayout.cshtml";
}

@if (isAdmin)
{
    <div class="container-fluid mt-4">
        <div class="card shadow">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fa-solid fa-gears me-2"></i>Admin Sipariş Detayı — #@Model.Id
                </h5>
                <span class="badge bg-light text-dark fs-6">Statü ID: @Model.StatusId</span>
            </div>

            <div class="card-body">
                <table class="table table-bordered align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width:90px;">Ürün</th>
                            <th>Ürün Kod</th>
                            <th>Ürün Adı</th>
                            <th>Birim Fiyat</th>
                            <th>Adet</th>
                            <th>Toplam</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OrderItems)
                        {
                            <tr>
                                <td>
                                    <img src="@item.ProductImageSnapshot" alt="@item.ProductNameSnapshot" style="width:70px; height:70px; object-fit:cover;" class="rounded border" />
                                </td>
                                <td>
                                    <span class="text-muted small">@item.ProductCodeSnapshot</span>
                                </td>
                                <td class="fw-semibold">
                                    @item.ProductNameSnapshot
                                </td>
                                <td>@item.PriceAtOrder.ToString("N2") ₺</td>
                                <td>@item.Miktar</td>
                                <td class="fw-bold">
                                    @((item.PriceAtOrder * item.Miktar).ToString("N2")) ₺
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <hr />

                <div class="row">
                    <div class="col-md-6">
                        <h6 class="fw-bold border-bottom pb-2">Müşteri Bilgisi</h6>
                        <p class="mb-1"><strong>Ad Soyad:</strong> @Model.Ad @Model.Soyad</p>
                        <p class="mb-1"><strong>Email:</strong> @Model.Email</p>
                        <p class="mb-1"><strong>Telefon:</strong> @Model.Telefon</p>
                        <p class="mb-1"><strong>Adres:</strong> @Model.AdresSatiri</p>
                    </div>

                    <div class="col-md-6">
                        <h6 class="fw-bold border-bottom pb-2">Sipariş & Ödeme Bilgisi</h6>
                        <p class="mb-1">
                            <strong>Tarih:</strong>
                            @Model.SiparisTarihi.ToString("dd.MM.yyyy HH:mm")
                        </p>
                        <p class="mb-1">
                            <strong>Ödeme:</strong> 
                            <span class="badge bg-info text-white">Iyzico / Kredi Kartı</span>
                        </p>
                        <p class="fw-bold text-primary fs-5 mt-2">
                            Toplam: @Model.ToplamFiyat.ToString("N2") ₺
                        </p>
                    </div>
                </div>
            </div>
            
            <div class="card-footer bg-light text-end py-3">
                <a asp-action="Index" class="btn btn-secondary me-2"><i class="fa-solid fa-arrow-left me-1"></i> Listeye Dön</a>

                @if (Model.StatusId == 7)
                {
                    <form asp-action="UpdateStatus" method="post" class="d-inline" id="adminApproveRefundForm">
                        <input type="hidden" name="orderId" value="@Model.Id" />
                        <input type="hidden" name="newStatusId" value="8" />
                        <button type="submit" class="btn btn-warning shadow-sm">
                            <i class="fa-solid fa-money-bill-transfer me-1"></i> İadeyi Onayla (Iyzico)
                        </button>
                    </form>
                }
                
                @if (Model.StatusId >= 1 && Model.StatusId <= 4)
                {
                    <form asp-action="UpdateStatus" method="post" class="d-inline" id="adminCancelForm">
                        <input type="hidden" name="orderId" value="@Model.Id" />
                        <input type="hidden" name="newStatusId" value="9" />
                        <button type="submit" class="btn btn-danger shadow-sm">
                            <i class="fa-solid fa-ban me-1"></i> Siparişi İptal Et (Iyzico)
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>
}
else
{
    <div class="container mt-4 mb-5">
        @if (TempData["Message"] != null || TempData["SuccessMessage"] != null || TempData["Error"] != null || TempData["ErrorMessage"] != null)
        {
            bool isError = TempData["Error"] != null || TempData["ErrorMessage"] != null;
            string alertClass = isError ? "alert-danger" : "alert-success";
            string iconClass = isError ? "fa-circle-xmark" : "fa-circle-check";
            string message = (TempData["Message"] ?? TempData["SuccessMessage"] ?? TempData["Error"] ?? TempData["ErrorMessage"]).ToString();

            <div class="alert @alertClass alert-dismissible fade show border-0 shadow-sm">
                <i class="fa-solid @iconClass me-2"></i>
                @message
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (Model == null)
        {
            <div class="alert alert-warning text-center">
                <h5>Sipariş verisi yüklenemedi.</h5>
            </div>
        }
        else
        {
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold text-dark">Sipariş No: #@Model.Id</h5>
                    
                    <div class="text-end">
                        @{
                            string statusName = Model.Status?.StatusDisplayName ?? "Bilinmiyor";
                            string badgeClass = Model.StatusId switch
                            {
                                9 => "bg-danger",
                                8 => "bg-dark",
                                7 => "bg-warning text-dark",
                                6 => "bg-success",
                                5 => "bg-info text-white",
                                _ => "bg-primary"
                            };
                        }
                        <span class="badge @badgeClass p-2 shadow-sm">
                            <i class="fa-solid fa-clock-rotate-left me-1"></i> @statusName
                        </span>
                    </div>
                </div>

                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light text-secondary">
                                <tr>
                                    <th style="width:80px;">Ürün</th>
                                    <th>Ürün Adı</th>
                                    <th>Birim Fiyat</th>
                                    <th class="text-center">Adet</th>
                                    <th class="text-end">Toplam</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in Model.OrderItems)
                                {
                                    <tr>
                                        <td>
                                            <img src="@item.ProductImageSnapshot" alt="@item.ProductNameSnapshot" style="width:70px; height:70px; object-fit:cover;" class="rounded border" />
                                        </td>
                                        <td class="fw-semibold text-dark">
                                            @item.ProductNameSnapshot
                                        </td>
                                        <td>@item.PriceAtOrder.ToString("N2") ₺</td>
                                        <td class="text-center">@item.Miktar</td>
                                        <td class="text-end fw-bold">
                                            @((item.PriceAtOrder * item.Miktar).ToString("N2")) ₺
                                        </td>
                                    </tr>
                                }
                            </tbody>

                            <tfoot>
                                <tr class="fw-bold bg-light">
                                    <td colspan="4" class="text-end py-3">Genel Toplam:</td>
                                    <td class="text-end text-primary fs-5 py-3">
                                        @Model.ToplamFiyat.ToString("N2") ₺
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>

                    <div class="row mt-4">
                        <div class="col-md-6 mb-3">
                            <div class="p-3 bg-light rounded-3 border h-100">
                                <h6 class="fw-bold mb-3"><i class="fa-solid fa-map-location-dot me-2 text-primary"></i>Teslimat Bilgileri</h6>
                                <p class="small mb-1 text-uppercase text-muted">Alıcı</p>
                                <p class="mb-2 fw-bold">@Model.Ad @Model.Soyad</p>
                                <p class="small mb-1 text-uppercase text-muted">Adres</p>
                                <p class="mb-0 small">@Model.AdresSatiri, @Model.Sehir</p>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="p-3 bg-light rounded-3 border h-100">
                                <h6 class="fw-bold mb-3"><i class="fa-solid fa-shield-check me-2 text-success"></i>Ödeme Özeti</h6>
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="small">Sipariş Tarihi:</span>
                                    <span class="small fw-bold">@Model.SiparisTarihi.ToString("dd.MM.yyyy HH:mm")</span>
                                </div>
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="small">Ödeme Türü:</span>
                                    <span class="small fw-bold text-success"><i class="fa-solid fa-credit-card me-1"></i> Iyzico / Kredi Kartı</span>
                                </div>
                                <hr class="my-2" />
                                <div class="d-flex justify-content-between">
                                    <span class="fw-bold">Tahsil Edilen:</span>
                                    <span class="fw-bold text-primary">@Model.ToplamFiyat.ToString("N2") ₺</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-footer bg-white text-end py-3 border-top-0">
                    <a asp-action="Index" class="btn btn-outline-secondary shadow-sm me-2">
                        <i class="fa-solid fa-arrow-left me-1"></i> Siparişlerim
                    </a>

                    @{
                        if (Model.StatusId >= 2 && Model.StatusId <= 4)
                        {
                            <form asp-action="CancelOrder" method="post" class="d-inline" id="userCancelForm">
                                <input type="hidden" name="orderId" value="@Model.Id" />
                                <button type="submit" class="btn btn-outline-danger shadow-sm">
                                    <i class="fa-solid fa-ban me-1"></i> Siparişi İptal Et
                                </button>
                            </form>
                        }
                        else if (Model.StatusId == 6)
                        {
                            <form asp-action="UserRequestReturn" method="post" class="d-inline" id="userReturnForm">
                                <input type="hidden" name="orderId" value="@Model.Id" />
                                <button type="submit" class="btn btn-outline-warning shadow-sm">
                                    <i class="fa-solid fa-arrow-rotate-left me-1"></i> İade Talebi Oluştur
                                </button>
                            </form>
                        }
                    }
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            
            // Ortak SweetAlert Tetikleyici Fonksiyonu
            function interceptFormSubmit(formId, title, text, icon, confirmText, confirmButtonColor = '#3085d6') {
                const form = document.getElementById(formId);
                if (form) {
                    form.addEventListener("submit", function (e) {
                        e.preventDefault(); 
                        
                        Swal.fire({
                            title: title,
                            text: text,
                            icon: icon,
                            showCancelButton: true,
                            confirmButtonColor: confirmButtonColor,
                            cancelButtonColor: '#6c757d',
                            confirmButtonText: confirmText,
                            cancelButtonText: 'Vazgeç',
                            customClass: {
                                confirmButton: 'btn btn-sm px-3 mx-1 text-white',
                                cancelButton: 'btn btn-sm px-3 mx-1 text-white'
                            },
                            buttonsStyling: true
                        }).then((result) => {
                            if (result.isConfirmed) {
                                form.submit(); 
                            }
                        });
                    });
                }
            }

            // 1. Admin: İadeyi Onaylama Formu
            interceptFormSubmit('adminApproveRefundForm', 'İade Onaylansın mı?', 'İadeyi onaylamak ve ilgili tutarı müşterinin kartına aktarmak istediğinize emin misiniz?', 'warning', 'Evet, Onayla', '#ffc107');

            // 2. Admin: Sipariş İptal Formu
            interceptFormSubmit('adminCancelForm', 'Sipariş İptal Edilsin mi?', 'Bu siparişi iptal edip ücreti müşterinin kartına aktarmak istediğinize emin misiniz?', 'error', 'Evet, İptal Et', '#dc3545');

            // 3. Kullanıcı: Sipariş İptal Formu
            interceptFormSubmit('userCancelForm', 'Siparişinizi İptal Etmek İstiyor musunuz?', 'Bu işlem geri alınamaz ve siparişiniz kalıcı olarak iptal edilir.', 'warning', 'Siparişi İptal Et', '#dc3545');

            // 4. Kullanıcı: İade Talebi Formu
            interceptFormSubmit('userReturnForm', 'İade Talebi Oluşturulsun mu?', 'Bu siparişe ait ürün/ürünler için iade süreci başlatılacaktır.', 'question', 'Talep Oluştur', '#ffc107');
        });
    </script>
}