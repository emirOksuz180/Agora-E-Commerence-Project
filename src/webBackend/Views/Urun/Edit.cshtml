@model UrunEditModel
@{
    Layout = "_AdminLayout";
}

<form method="post" enctype="multipart/form-data">
<div class="row">
    <div class="col-md-9">
        <div class="card shadow">
            <div class="card-header py-1 d-flex justify-content-between align-items-center">
                <h5 class="card-title">Ürün Güncelle</h5>
                <a asp-action="Index" class="btn btn-sm btn-primary">
                    <i class="fa-solid fa-list"></i>
                </a>
            </div>
            <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <input type="hidden" asp-for="ProductId">
                    <input type="hidden" asp-for="ImageUrl">
                    
                    <div class="row mb-3">
                        <label asp-for="ProductName" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="ProductName" class="form-control">
                            <span asp-validation-for="ProductName" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="Description" class="col-sm-2 col-form-label">Açıklama</label>
                        <div class="col-sm-10">
                            <textarea asp-for="Description" rows="3" class="form-control"></textarea>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="Price" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="Price" class="form-control" type="text">
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>
                    </div>

                    @* --- STOK ALANI ENTEGRASYONU --- *@
                    <div class="row mb-3">
                        <label asp-for="Stock" class="col-sm-2 col-form-label">Stok Adedi</label>
                        <div class="col-sm-10">
                            <input asp-for="Stock" 
                                type="number" 
                                class="form-control" 
                                min="0" 
                                step="any"
                                onkeypress="return (event.charCode >= 48 && event.charCode <= 57)"
                                placeholder="0">
                            <span asp-validation-for="Stock" class="text-danger"></span>
                            <small class="text-muted">Mevcut stok miktarını buradan güncelleyebilirsiniz.</small>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label asp-for="Weight" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="Weight" class="form-control" type="number" step="0.01">
                            <span asp-validation-for="Weight" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label asp-for="Width" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="Width" class="form-control" type="number" step="0.01">
                            <span asp-validation-for="Width" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label asp-for="Height" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="Height" class="form-control" type="number" step="0.01">
                            <span asp-validation-for="Height" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label asp-for="Length" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="Length" class="form-control" type="number" step="0.01">
                            <span asp-validation-for="Length" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-10 offset-sm-2">
                            <small class="text-muted">
                                Desi otomatik hesaplanır (En × Boy × Yükseklik / 3000)
                            </small>
                        </div>
                    </div>

                    
                    <div class="row mb-3">
                        <label class="col-sm-2 col-form-label font-weight-bold">Kargo Firmaları</label>
                        <div class="col-sm-10">
                            <div class="card bg-light border-0 shadow-sm">
                                <div class="card-body py-2">
                                    <div class="row">
                                        @if (ViewBag.CarrierList != null)
                                        {
                                            foreach (var carrier in (List<Carrier>)ViewBag.CarrierList)
                                            {
                                                // Eğer Edit modundaysak ve bu kargo ürünün Carriers listesindeyse 'checked' gelsin
                                                bool isSelected = Model?.SelectedCarrierIds != null && Model.SelectedCarrierIds.Contains(carrier.Id);
                                                
                                                <div class="col-md-4 py-1">
                                                    <div class="form-check form-switch">
                                                        <input type="checkbox" 
                                                            name="selectedCarrierIds" 
                                                            value="@carrier.Id" 
                                                            class="form-check-input" 
                                                            id="carrier_@carrier.Id"
                                                            @(isSelected ? "checked" : "")>
                                                        <label class="form-check-label" for="carrier_@carrier.Id">
                                                            @carrier.CarrierName
                                                        </label>
                                                    </div>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <div class="col-12 text-muted small italic">Aktif kargo firması bulunamadı.</div>
                                        }
                                    </div>
                                </div>
                            </div>
                            <small class="text-muted">Bu ürünü taşıyabilecek kargo şirketlerini seçiniz.</small>
                        </div>
                    </div>
                    

                    <div class="row mb-3">
                        <label asp-for="IsActive" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="IsActive" class="form-check-input">
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="AnaSayfa" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="AnaSayfa" class="form-check-input">
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label for="CategoryId" class="col-sm-2 col-form-label">Kategori</label>
                        <div class="col-sm-10">
                            <select asp-for="CategoryId" asp-items="ViewBag.Kategoriler" class="form-select">
                                <option value="">Seçiniz</option>
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-10 offset-sm-2">
                            <button type="submit" class="btn btn-primary">Kaydet</button>
                        </div>
                    </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow">
            <div class="card-body text-center">
                <img src="@Model.ImageUrl" class="img-thumbnail" alt="">
                <input asp-for="ImageFile" type="file" class="form-control mt-3">
                <span asp-validation-for="ImageFile" class="text-danger"></span>
            </div>
        </div>
    </div>
</div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        $(document).ready(function() {
            // Desi Hesaplama
            $("#Width, #Height, #Length").on("input", function() {
                let w = parseFloat($("#Width").val()) || 0;
                let h = parseFloat($("#Height").val()) || 0;
                let l = parseFloat($("#Length").val()) || 0;
                let desi = (w * h * l) / 3000;
                $("#Desi").val(desi.toFixed(2));
            });

            // Sayı formatı ayarı
            $.validator.methods.number = function (value, element) {
                return this.optional(element) || /^-?(?:\d+|\d{1,3}(?:[\s\.,]\d{3})+)(?:[\.,]\d+)?$/.test(value);
            }
        });
    </script>
}