@model List<UrunViewModel>

@{
    Layout = "_AdminLayout";
}

<div class="row">
    <div class="col">
        <div class="card shadow">
            <div class="card-header py-2 d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0">Ürün Yönetimi</h5>

                @if(User.IsInRole("Admin") || User.HasClaim("Permission", "Product.Create")) {
                    <a asp-controller="Urun" asp-action="Create" class="btn btn-sm btn-primary">
                        <i class="fa-solid fa-plus me-1"></i> Yeni Ürün
                    </a>
                }
            </div>
            <div class="card-body">
                @if(User.IsInRole("Admin") || User.HasClaim("Permission", "Product.View")) {
                    <form method="get">
                        <div class="input-group mb-3">
                            <select name="kategori" asp-items="ViewBag.Categories" class="form-select">
                                <option value="" selected>Tüm Kategoriler</option>
                            </select>
                            <button class="btn btn-secondary" type="submit">
                                <i class="fa-solid fa-magnifying-glass"></i> Filtrele
                            </button>
                        </div>
                    </form>
                }
                
                @if(Model == null || Model.Count == 0) {
                    <div class="alert alert-warning">Ürün bulunamadı.</div>
                }
                else {
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover table-striped align-middle mb-0">
                            <thead class="table-secondary">
                                <tr class="text-center">
                                    <th style="width: 50px;">ID</th>
                                    <th style="width: 70px;">Resim</th>
                                    <th>Ürün Adı</th>
                                    <th>Fiyat</th>
                                    <th style="width: 80px;">Stok</th>
                                    <th style="width: 50px;">Aktif</th>
                                    <th style="width: 50px;">AnaS.</th>
                                    <th>Kategori</th>
                                    <th title="Ağırlık (kg)">Ağr.</th>
                                    <th title="Boyutlar (En x Boy x Yükseklik)">Boyut (cm)</th>
                                    <th>Desi</th>
                                    <th style="width: 100px;">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach(var urun in Model) {
                                    <tr>                  
                                        <td class="text-center">@urun.ProductId</td>
                                        <td class="text-center">
                                            <img src="@urun.ImageUrl" class="rounded" style="width: 50px; height: 50px; object-fit: cover;" alt="@urun.ProductName">
                                        </td>
                                        <td class="fw-bold">@urun.ProductName</td>
                                        <td class="text-nowrap text-end">@urun.Price.ToString("C2")</td>
                                        
                                        @* Stok Kolonu Entegrasyonu *@
                                        <td class="text-center">
                                            @if (urun.Stock <= 0) {
                                                <span class="badge bg-secondary w-100">Tükendi</span>
                                            } else if (urun.Stock <= 5) {
                                                <span class="badge bg-danger shadow-sm w-100" title="Kritik Stok Seviyesi">
                                                    <i class="fa-solid fa-fire-flame-curved me-1"></i> @urun.Stock
                                                </span>
                                            } else if (urun.Stock <= 20) {
                                                <span class="badge bg-warning text-dark w-100" title="Stok Azalıyor">
                                                    @urun.Stock
                                                </span>
                                            } else {
                                                <span class="badge border text-dark w-100">
                                                    @urun.Stock
                                                </span>
                                            }
                                        </td>

                                        <td class="text-center">
                                            @if(urun.IsActive) {
                                                <i class="fa-solid fa-circle-check text-success"></i>
                                            } else {
                                                <i class="fa-solid fa-circle-xmark text-danger"></i>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @if(urun.AnaSayfa) {
                                                <i class="fa-solid fa-star text-warning"></i>
                                            } else {
                                                <i class="fa-solid fa-minus text-muted"></i>
                                            }
                                        </td>
                                        <td><span class="badge bg-light text-dark border">@urun.CategoryName</span></td>

                                        <td class="text-center">@(urun.Weight?.ToString("N2") ?? "-")</td>
                                        <td class="text-center small">
                                            @if(urun.Width > 0) {
                                                <span>@urun.Width x @urun.Length x @urun.Height</span>
                                            } else {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            <span class="badge bg-info text-dark fw-bold">@urun.Desi</span>
                                        </td>

                                        <td class="text-center">
                                            <div class="d-flex justify-content-center gap-1">
                                                @if(User.IsInRole("Admin") || User.HasClaim("Permission", "Product.Edit")) {
                                                    <a asp-controller="Urun" asp-action="Edit" asp-route-id="@urun.ProductId" class="btn btn-primary btn-sm" title="Düzenle">
                                                        <i class="fa-solid fa-pen-to-square"></i>
                                                    </a>
                                                }

                                                @if (User.IsInRole("Admin") || User.HasClaim("Permission", "Product.Delete")) {
                                                    <button type="button" 
                                                            onclick="deleteProduct(@urun.ProductId, '@Html.Raw(urun.ProductName.Replace("'", "\\'"))')" 
                                                            class="btn btn-danger btn-sm" title="Sil">
                                                        <i class="fa-solid fa-trash"></i>
                                                    </button>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function deleteProduct(id, name) {
            Swal.fire({
                title: 'Emin misiniz?',
                text: name + " isimli ürün kalıcı olarak silinecek!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Evet, Sil!',
                cancelButtonText: 'Vazgeç',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    var form = document.createElement("form");
                    form.setAttribute("method", "post");
                    form.setAttribute("action", "/Urun/Delete/" + id);

                    var token = $('input[name="__RequestVerificationToken"]').val();
                    if(token){
                        var tokenInput = document.createElement("input");
                        tokenInput.setAttribute("type", "hidden");
                        tokenInput.setAttribute("name", "__RequestVerificationToken");
                        tokenInput.setAttribute("value", token);
                        form.appendChild(tokenInput);
                    }

                    document.body.appendChild(form);
                    form.submit();
                }
            });
        }
    </script>
}