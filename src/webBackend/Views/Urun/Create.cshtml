@model UrunViewModel
@{
    Layout = "_AdminLayout";
}

<div class="row">
    <div class="col-md-12">
        <div class="card shadow">
            <div class="card-header py-1 d-flex justify-content-between align-items-center">
                <h5 class="card-title">@(Model?.ProductId > 0 ? "Ürün Düzenle" : "Yeni Ürün Ekle")</h5>
                <a asp-controller="Urun" asp-action="Index" class="btn btn-sm btn-primary">
                    <i class="fa-solid fa-list"></i>
                </a>
            </div>
            <div class="card-body">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <form method="post" enctype="multipart/form-data">
                    @if (Model?.ProductId > 0)
                    {
                        <input type="hidden" asp-for="ProductId" />
                    }

                    <div class="row mb-3">
                        <label asp-for="ProductName" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="ProductName" class="form-control">
                            <span asp-validation-for="ProductName" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label asp-for="Description" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <textarea asp-for="Description" rows="3" class="form-control"></textarea>
                        </div>
                    </div>

                    @* --- 💡 1. YENİ EKLENEN ALAN: ALIŞ FİYATI --- *@
                    <div class="row mb-3">
                        <label asp-for="PurchasePrice" class="col-sm-2 col-form-label">Alış Fiyatı</label>
                        <div class="col-sm-10">
                            <input asp-for="PurchasePrice" class="form-control" type="text" placeholder="0,00">
                            <span asp-validation-for="PurchasePrice" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label asp-for="Price" class="col-sm-2 col-form-label">Satış Fiyatı</label>
                        <div class="col-sm-10">
                            <input asp-for="Price" class="form-control" type="text" placeholder="0,00">
                            @* Custom js validasyon mesajını basabilmek için id ekledik *@
                            <span id="price-js-error" class="text-danger field-validation-valid"></span>
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>
                    </div>

                    @* --- STOK ALANI BAŞLANGIÇ --- *@
                    @* <div class="row mb-3">
                        <label asp-for="Stock" class="col-sm-2 col-form-label">Stok Adedi</label>
                        <div class="col-sm-10">
                            <input asp-for="Stock" 
                                type="number" 
                                class="form-control" 
                                min="0" 
                                step="any"
                                onkeypress="return (event.charCode >= 48 && event.charCode <= 57)"
                                placeholder="0">
                            <small class="text-muted">Sadece tam sayı girişi yapabilirsiniz.</small>
                        </div>
                    </div> *@
                    

                    <div class="row mb-3">
                        <label asp-for="Weight" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="Weight" class="form-control" type="number" step="0.01">
                            <span asp-validation-for="Weight" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label asp-for="Width" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="Width" class="form-control" type="number" step="0.01">
                            <span asp-validation-for="Width" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label asp-for="Height" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="Height" class="form-control" type="number" step="0.01">
                            <span asp-validation-for="Height" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label asp-for="Length" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="Length" class="form-control" type="number" step="0.01">
                            <span asp-validation-for="Length" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-10 offset-sm-2">
                            <small class="text-muted">
                                Desi otomatik hesaplanır (En × Boy × Yükseklik / 3000)
                            </small>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-2 col-form-label font-weight-bold">Kargo Firmaları</label>
                        <div class="col-sm-10">
                            <div class="card bg-light border-0 shadow-sm">
                                <div class="card-body py-2">
                                    <div class="row">
                                        @if (ViewBag.CarrierList != null)
                                        {
                                            foreach (var carrier in (List<Carrier>)ViewBag.CarrierList)
                                            {
                                                bool isSelected = Model?.SelectedCarrierIds != null && Model.SelectedCarrierIds.Contains(carrier.Id);
                                                
                                                <div class="col-md-4 py-1">
                                                    <div class="form-check form-switch">
                                                        <input type="checkbox" 
                                                            name="selectedCarrierIds" 
                                                            value="@carrier.Id" 
                                                            class="form-check-input" 
                                                            id="carrier_@carrier.Id"
                                                            @(isSelected ? "checked" : "")>
                                                        <label class="form-check-label" for="carrier_@carrier.Id">
                                                            @carrier.CarrierName
                                                        </label>
                                                    </div>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <div class="col-12 text-muted small italic">Aktif kargo firması bulunamadı.</div>
                                        }
                                    </div>
                                </div>
                            </div>
                            <small class="text-muted">Bu ürünü taşıyabilecek kargo şirketlerini seçiniz.</small>
                        </div>
                    </div>
                    

                    <div class="row mb-3">
                        <label asp-for="IsActive" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="IsActive" class="form-check-input">
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label asp-for="AnaSayfa" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="AnaSayfa" class="form-check-input">
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label asp-for="ImageFile" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="ImageFile" type="file" class="form-control">
                            <span asp-validation-for="ImageFile" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label for="CategoryId" class="col-sm-2 col-form-label">Kategori</label>
                        <div class="col-sm-10">
                            <select asp-for="CategoryId" asp-items="ViewBag.Kategoriler" class="form-control">
                                <option value="">Kategori seçiniz</option>
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-10 offset-sm-2">
                            @* 💡 JS ile kontrol etmek için submit butonuna id="btnSubmit" ekledik *@
                            <button type="submit" id="btnSubmit" class="btn btn-primary">Kaydet</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial") 
    
    <script>
        $(document).ready(function() {
            // Desi Hesaplama
            $("#Width, #Height, #Length").on("input", function() {
                let w = parseFloat($("#Width").val()) || 0;
                let h = parseFloat($("#Height").val()) || 0;
                let l = parseFloat($("#Length").val()) || 0;
                let desi = (w * h * l) / 3000;
                $("#DesiDisplay").val(desi.toFixed(2)); 
            });

            // 💡 2. YENİ EKLENEN KISIM: ANLIK FİYAT KONTROLÜ VE UYARI SİSTEMİ
            function checkPriceValidation() {
                // Türkçe virgüllü formatı JavaScript'in anlayacağı nokta formatına çeviriyoruz
                let purchasePriceRaw = $("#PurchasePrice").val() || "0";
                let priceRaw = $("#Price").val() || "0";

                let purchasePrice = parseFloat(purchasePriceRaw.replace('.', '').replace(',', '.')) || 0;
                let price = parseFloat(priceRaw.replace('.', '').replace(',', '.')) || 0;

                // Eğer satış fiyatı girilmişse ve alış fiyatından küçükse
                if (priceRaw !== "" && price < purchasePrice) {
                    $("#price-js-error").text("Satış fiyatı, alış fiyatından (" + purchasePrice.toLocaleString('tr-TR', { minimumFractionDigits: 2 }) + " TL) düşük olamaz.");
                    $("#btnSubmit").prop("disabled", true); // Butonu kilitle
                } else {
                    $("#price-js-error").text(""); // Hatayı temizle
                    $("#btnSubmit").prop("disabled", false); // Buton kilidini aç
                }
            }

            // Alış veya Satış fiyatı kutularına bir şey yazıldığında kontrol et
            $("#Price, #PurchasePrice").on("input", function() {
                checkPriceValidation();
            });

            // Checkbox'lar için Enter engelleme
            $('.form-check-input').on('keydown', function(e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    $(this).prop('checked', !$(this).prop('checked'));
                }
            });

            // Sayı formatı validasyon ayarı
            $.validator.methods.number = function (value, element) {
                return this.optional(element) || /^-?(?:\d+|\d{1,3}(?:[\s\.,]\d{3})+)(?:[\.,]\d+)?$/.test(value);
            }
        });
    </script>
}