@model Product

@* Üst kısımdaki görsel taşmasını engelleyen stil *@
<style>
    .img-big-wrap img {
        max-height: 400px;
        width: auto;
        max-width: 100%;
        object-fit: contain;
    }
    .card-img-top {
        height: 180px;
        object-fit: contain;
    }
</style>

@section Bar {
    @await Component.InvokeAsync("Navbar")
}

<section class="mt-3">
    <div class="container">
        <div class="row">
            <div class="col-lg-5">
                <div class="gallery-wrap">
                    <div class="img-big-wrap img-thumbnail bg-white text-center">
                        <a href="@Model.ImageUrl" data-type="image" data-fslightbox>
                            <img src="@Model.ImageUrl" alt="@Model.ProductName">
                        </a>
                    </div>
                    @* Thumbs wrap kısmı opsiyonel, görselin altına küçük resimler dizer *@
                </div>
            </div>
            <div class="col-lg-7">
                <article>
                    <h4 class="title text-dark">@Model.ProductName</h4>
                    <p class="text-success fw-bold">Stokta Mevcut</p>
                    
                    <div class="mb-3">
                        @if (Model.Price <= 0)
                        {
                            <b class="price h4 text-success">Ücretsiz</b>
                        }
                        else
                        {
                            <b class="price h4 text-primary">@Model.Price.ToString("C2")</b>
                        }
                    </div>

                    <div class="product-description mb-3 text-muted">@Model.ProductDescription</div>
                    
                    <div class="buttons">
                        <form action="/Cart/AddToCart" method="post" class="d-inline">
                            <input type="hidden" name="urunId" value="@Model.ProductId">
                            <button type="submit" class="btn btn-warning px-4">
                                <i class="fa fa-shopping-basket me-1"></i> Sepete Ekle
                            </button>
                        </form>
                        <button class="btn btn-outline-danger ms-2">
                            <i class="fa-regular fa-heart"></i>
                        </button>
                    </div>
                </article>
            </div>
        </div>
    </div>
</section>

@{
    var urunler = (List<Product>)ViewData["BenzerUrunler"]!;

    if (urunler != null && urunler.Count > 0)
    {
        <section class="mt-5 border-top pt-4">
            <div class="container">
                <h4 class="mb-4">Benzer Ürünler</h4>
                <div class="row gy-3">
                    @foreach (var item in urunler)
                    {
                        <div class="col-lg-3 col-sm-6">
                            <div class="card shadow-sm h-100 border-0">
                                <img src="@item.ImageUrl" class="card-img-top p-3" alt="@item.ProductName">
                                <div class="card-body d-flex flex-column">
                                    <a asp-controller="Urun" asp-action="Details" asp-route-id="@item.ProductId" 
                                       class="text-dark text-decoration-none fw-bold text-truncate d-block mb-2">@item.ProductName</a>
                                    
                                    <div class="mt-auto">
                                        <div class="mb-2">
                                            @if (item.Price <= 0)
                                            {
                                                <span class="text-success fw-bold">Ücretsiz</span>
                                            }
                                            else
                                            {
                                                <span class="text-primary fw-bold">@item.Price.ToString("C2")</span>
                                            }
                                        </div>

                                        @* BENZER ÜRÜN SEPETE EKLEME FORMU *@
                                        <form action="/Cart/AddToCart" method="post">
                                            <input type="hidden" name="urunId" value="@item.ProductId">
                                            <button type="submit" class="btn btn-outline-warning btn-sm w-100">
                                                <i class="fa fa-shopping-basket me-1"></i> Sepete Ekle
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </section>
    }
}