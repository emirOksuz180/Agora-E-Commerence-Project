@model Product

@* Üst kısımdaki görsel taşmasını engelleyen stil *@
<style>
    .img-big-wrap img {
        max-height: 400px;
        width: auto;
        max-width: 100%;
        object-fit: contain;
    }
    .card-img-top {
        height: 180px;
        object-fit: contain;
    }
</style>

@section Bar {
    @await Component.InvokeAsync("Navbar")
}

<section class="mt-3">
    <div class="container">
        <div class="row">
            <div class="col-lg-5">
                <div class="gallery-wrap">
                    <div class="img-big-wrap img-thumbnail bg-white text-center">
                        <a href="@Model.ImageUrl" data-type="image" data-fslightbox>
                            <img src="@Model.ImageUrl" alt="@Model.ProductName">
                        </a>
                    </div>
                </div>
            </div>
            <div class="col-lg-7">
                <article>
                    <h4 class="title text-dark">@Model.ProductName</h4>
                    
                    @* --- DİNAMİK STOK DURUMU --- *@
                    <div class="stock-status mb-2">
                        @if (Model.Stock > 10)
                        {
                            <p class="text-success fw-bold">
                                <i class="fa-solid fa-check-circle me-1"></i> Stokta Mevcut
                            </p>
                        }
                        else if (Model.Stock > 0 && Model.Stock <= 10)
                        {
                            <p class="text-warning fw-bold">
                                <i class="fa-solid fa-triangle-exclamation me-1"></i> Son @Model.Stock Ürün!
                            </p>
                        }
                        else
                        {
                            <p class="text-danger fw-bold">
                                <i class="fa-solid fa-circle-xmark me-1"></i> Stokta Yok
                            </p>
                        }
                    </div>
                    
                    <div class="mb-3">
                        @if (Model.Price <= 0)
                        {
                            <b class="price h4 text-success">Ücretsiz</b>
                        }
                        else
                        {
                            <b class="price h4 text-primary">@Model.Price.ToString("C2")</b>
                        }
                    </div>

                    <div class="product-description mb-3 text-muted">@Model.ProductDescription</div>
                    
                    <div class="buttons">
                        <form action="/Cart/AddToCart" method="post" class="d-inline">
                            <input type="hidden" name="urunId" value="@Model.ProductId">
                            
                            @* Stok yoksa butonu pasif yapıyoruz *@
                            @if (Model.Stock > 0)
                            {
                                <button type="submit" class="btn btn-warning px-4">
                                    <i class="fa fa-shopping-basket me-1"></i> Sepete Ekle
                                </button>
                            }
                            else
                            {
                                <button type="button" class="btn btn-secondary px-4" disabled>
                                    <i class="fa-solid fa-ban me-1"></i> Stok Tükendi
                                </button>
                            }
                        </form>
                        <button type="button" 
                                class="btn btn-outline-danger ms-2 fav-button" 
                                data-product-id="@Model.ProductId">
                            <i class="fa-regular fa-heart"></i>
                        </button>
                    </div>
                </article>
            </div>
        </div>
    </div>
</section>

@* ... Benzer Ürünler Kısmı Aynı Kalabilir ... *@