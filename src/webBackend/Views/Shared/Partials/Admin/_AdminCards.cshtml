<div class="row">
    <div class="col-xl-4 col-md-6 mb-4">
        <div class="card border-left-primary shadow py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col">
                        <div class="fw-bold text-primary text-uppercase mb-1">Satış</div>
                        <div class="h5 mb-0 fw-bold">@(((decimal?)ViewBag.TotalSales)?.ToString("N2") ?? "0,00") ₺</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-dollar-sign fa-2x text-grey-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

   
    <div class="col-xl-4 col-md-6 mb-4">
        <div class="card border-left-success shadow py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col">
                        <div class="fw-bold text-success text-uppercase mb-1">Sipariş</div>
                        <div class="h5 mb-0 fw-bold">@ViewBag.OrderCount</div>
                    </div>
                    <div class="col-auto">
                        <i class="fa-solid fa-truck fa-2x text-grey-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    
    <div class="col-xl-4 col-md-12 mb-4">
        <div class="card border-left-warning shadow py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col">
                        <div class="fw-bold text-warning text-uppercase mb-1">Ürün Adedi</div>
                        <div class="h5 mb-0 fw-bold">@ViewBag.ProductCount</div>
                    </div>
                    <div class="col-auto">
                        <i class="fa-solid fa-list fa-2x text-grey-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>