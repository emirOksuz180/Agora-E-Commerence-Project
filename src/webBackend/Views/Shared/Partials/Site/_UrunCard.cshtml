@model Product

<div class="card shadow h-100">
    <div class="img-wrap">
        @if (Model.Price > 0) 
        {
            <span class="badge bg-success">İndirim</span>
        }
        <img src="@($"{Context.Request.PathBase}{Model.ImageUrl}")" alt="@Model.ProductName" class="card-img-top" style="object-fit: cover; height: 200px;">
    </div>

    <div class="border-top info-wrap p-3">
        @* FAVORİ BUTONU BURADA BAŞLIYOR *@
        <div class="float-end">
            <button type="button" 
                    class="btn btn-light btn-sm border-0 fav-button" 
                    data-product-id="@Model.ProductId">
                <i class="fa-regular fa-heart text-danger fs-5"></i>
            </button>
        </div>
        @* FAVORİ BUTONU BURADA BİTTİ *@

        <a asp-controller="Urun" asp-action="Details" asp-route-id="@Model.ProductId"
           class="title text-truncate d-block mb-2 fw-bold text-decoration-none text-dark">
            @Model.ProductName
        </a>
        
        <div class="price-wrap">
            @if (Model.Price <= 0)
            {
                <span class="badge bg-success px-3 py-2" style="font-size: 0.9rem;">Ücretsiz</span>
            }
            else
            {
                <span class="price-discount fw-bold text-primary">@Model.Price.ToString("C2")</span>
            }
        </div>
    </div>
</div>