@using webBackend.Controllers
@model SecuritySettingsViewModel

@section Bar {
    <section class="bg-primary p-3">
        <div class="container">
            <nav>
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item">
                        <a asp-controller="Home" asp-action="Index" class="text-white text-decoration-none">Anasayfa</a>
                    </li>
                    <li class="breadcrumb-item text-white-50">Hesap Güvenliği</li>
                </ol>
            </nav>
        </div>
    </section>
}

<section class="mt-3">
    <div class="container">
        <div class="row">
            @* 1. SOL KOLON: ACCOUNT SIDEBAR *@
            <div class="col-md-3">
                <div class="list-group mb-3 shadow-sm">
                    @await Html.PartialAsync("Partials/Site/_AccountSideBar")
                </div>
            </div>

            @* 2. SAĞ KOLON: GÜVENLİK AYARLARI *@
            <div class="col-md-9">
                <div class="card shadow border-0" style="border-radius: 15px;">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center mb-4">
                            <i class="fa-solid fa-shield-halved text-primary fa-2xl me-3"></i>
                            <h4 class="fw-bold mb-0">Hesap Güvenliği</h4>
                        </div>

                        <div class="alert alert-light border-0 shadow-sm rounded-3 p-3 mb-4">
                            <div class="d-flex align-items-center justify-content-between">
                                <div>
                                    <h6 class="mb-1 fw-bold text-dark">İki Adımlı Doğrulama (E-posta)</h6>
                                    <p class="text-muted small mb-0">
                                        Giriş yaparken e-postanıza gelen 6 haneli kodu kullanarak hesabınızı ekstra koruma altına alırsınız.
                                    </p>
                                </div>
                                
                                <form asp-action="ToggleTwoFactor" method="post">
                                    @Html.AntiForgeryToken()
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" role="switch" 
                                               id="twoFactorSwitch" onchange="this.form.submit()" 
                                               @(Model.IsTwoFactorEnabled ? "checked" : "") 
                                               style="cursor:pointer; width: 3.2em; height: 1.6em;">
                                    </div>
                                </form>
                            </div>
                        </div>

                        @* Bilgilendirme Notu *@
                        <div class="bg-light p-3 rounded-3 mt-4">
                            <div class="d-flex">
                                <i class="fa-solid fa-circle-info text-info mt-1 me-2"></i>
                                <p class="small text-muted mb-0">
                                    <strong>MFA (Multi-Factor Authentication) Hakkında:</strong> Bu özellik aktif edildiğinde, sistem kimliğinizi 
                                    doğrulamak için hem şifrenizi hem de tek kullanımlık kodunuzu talep eder. Bu, hesabınızın güvenliğini 
                                    en üst seviyeye çıkarır.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>